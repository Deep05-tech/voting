generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Team {
  id        String   @id @default(cuid())
  name      String
  videoUrl  String?
  createdAt DateTime @default(now())
  votes     Vote[]
}

model Vote {
  id        String   @id @default(cuid())
  rating    Int      @default(0)
  voterName String
  sessionId String
  ipAddress String
  teamId    String
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id])
}
